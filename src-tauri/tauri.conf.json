{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ScreeniesEditor",
  "version": "0.9.0",
  "identifier": "com.screenies-editor.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ScreeniesEditor",
        "width": 1320,
        "height": 860,
        "minWidth": 900,
        "minHeight": 620,
        "center": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "category": "GraphicsAndDesign",
    "shortDescription": "Screenshot Roleplay editor untuk komunitas SA-MP"
  }
}
